# Migrator wallet key, used to sign FWSS create-data-set / pull / AddPieces calls.
# Must be the wallet that owns USDFC, holds operator approval for FWSS, and is the
# data set's FWSS payer. Copy this file to .env (gitignored) and set the value.
PRIVATE_KEY=0xreplace-me

# Optional: override the JSON-RPC URL used for chain reads and the base-fee gate.
# Defaults to a public endpoint per --network in packages/cli/src/gas.ts.
# RPC_URL=https://api.calibration.node.glif.io/rpc/v1
