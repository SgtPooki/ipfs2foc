{
  "name": "ipfs2foc",
  "version": "0.1.0",
  "description": "Migrate already-pinned IPFS CIDs onto Filecoin Onchain Cloud without re-chunking.",
  "keywords": [
    "ipfs",
    "filecoin",
    "pdp",
    "cli",
    "migration"
  ],
  "homepage": "https://github.com/SgtPooki/ipfs2foc#readme",
  "bugs": "https://github.com/SgtPooki/ipfs2foc/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SgtPooki/ipfs2foc.git"
  },
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "bin": {
    "ipfs2foc": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@filoz/synapse-core": "^0.5.2",
    "@filoz/synapse-sdk": "^0.41.0",
    "@helia/block-brokers": "^5.2.4",
    "@helia/car": "^5.4.2",
    "@helia/routers": "^5.1.1",
    "@helia/utils": "^2.5.2",
    "@ipld/car": "^5.4.0",
    "@libp2p/autonat": "^3.0.20",
    "@libp2p/identify": "^4.1.6",
    "@libp2p/ping": "^3.1.6",
    "@libp2p/tcp": "^11.0.20",
    "@libp2p/upnp-nat": "^4.0.20",
    "@libp2p/websockets": "^10.1.14",
    "@libp2p/yamux": "^8.0.1",
    "@web3-storage/data-segment": "^5.3.0",
    "blockstore-core": "^6.1.3",
    "datastore-core": "^11.0.4",
    "iso-filecoin": "^7.4.7",
    "libp2p": "^3.3.2",
    "multiformats": "^13.4.1",
    "viem": "^2.21.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
